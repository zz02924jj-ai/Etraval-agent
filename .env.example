# =============================================
# Etraval-agent 环境变量配置示例
# 复制此文件为 .env 并填入真实值
# =============================================

# === GLM 系列模型 ===
GLM_API_KEY=your_api_key_here
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=glm-4-32b
GLM_4V_MODEL=glm-4v-9b

# === 和风天气 API ===
QW_API_KEY=your_weather_api_key

# === MySQL ===
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_PASSWORD=12345678

# === 票务 API（留空表示使用虚拟数据） ===
REAL_TICKET_API=false
CTRIP_API_URL=
CTRIP_API_KEY=
DAMAI_API_URL=
DAMAI_API_KEY=

# === Milvus（可选） ===
MILVUS_HOST=localhost
MILVUS_PORT=19530

# === MCP 服务地址（Docker 部署时自动配置） ===
# MCP_WEATHER_URL=http://localhost:6001
# MCP_TICKET_URL=http://localhost:6002
# MCP_KNOWLEDGE_URL=http://localhost:6003
# MCP_REVIEW_URL=http://localhost:6004

# === A2A Agent 地址（Docker 部署时自动配置） ===
# A2A_WEATHER_URL=http://localhost:5005
# A2A_TICKET_URL=http://localhost:5006
# A2A_ROUTER_URL=http://localhost:6666
# A2A_ATTRACTION_URL=http://localhost:5007
# A2A_VISUAL_URL=http://localhost:5008
